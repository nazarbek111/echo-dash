# --- Database ---
# Dev (SQLite) — works out of the box:
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL) — uncomment and set:
# DATABASE_URL="postgresql://user:password@host:5432/echodash?schema=public"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=4000
NODE_ENV=development

# --- CORS ---
CLIENT_URL="http://localhost:5173"
